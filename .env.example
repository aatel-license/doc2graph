# ─────────────────────────────────────────────────────────────────────────────
# doc2graph — Configurazione LLM
# Copia questo file in .env e modifica i valori
# ─────────────────────────────────────────────────────────────────────────────

# ── Server LLM ───────────────────────────────────────────────────────────────
# LM-Studio (default):
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio

# Ollama:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...

# ── Modello ───────────────────────────────────────────────────────────────────
# Lascia vuoto per auto-discovery (primo modello disponibile)
LLM_MODEL=

# Esempi:
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=llama-3.1-8b-instruct
# LLM_MODEL=mistral-7b-instruct-v0.3

# ── Parametri LLM ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_RETRY=3
LLM_TIMEOUT=120

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=6000
CHUNK_OVERLAP=500
# Usa tiktoken per chunk precisi in token (richiede: pip install tiktoken)
USE_TOKEN_CHUNKING=false

# ── Processing ───────────────────────────────────────────────────────────────
# Worker paralleli per l'estrazione dei chunk (attenzione ai rate limit)
PARALLEL_WORKERS=1

# Soglia fuzzy per deduplicare nodi simili (0-100, default 90)
FUZZY_MERGE_THRESHOLD=90

# Dimensione batch per arricchimento relazioni
ENRICH_BATCH_SIZE=30

# Quanti archi verificare con LLM (0 = tutti, usato solo con --verify)
VERIFY_SAMPLE_SIZE=0
