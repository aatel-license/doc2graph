# ─────────────────────────────────────────────────────────────────
#  doc2graph — Configurazione LLM (OpenAI-compatible)
# ─────────────────────────────────────────────────────────────────

# ── LM-Studio (default) ──────────────────────────────────────────
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=
LLM_MODEL=

# ── Ollama ────────────────────────────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# ── OpenAI ────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# ── Groq ──────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=llama-3.1-70b-versatile

# ── LM-Studio con modello specifico ──────────────────────────────
# LLM_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF

# ─────────────────────────────────────────────────────────────────
#  Parametri opzionali
# ─────────────────────────────────────────────────────────────────

# Token massimi per risposta LLM (default 4096)
LLM_MAX_TOKENS=40960

# Dimensione chunk di testo in caratteri (default 6000)
# Riduci se il modello ha context window piccola
CHUNK_SIZE=6000
